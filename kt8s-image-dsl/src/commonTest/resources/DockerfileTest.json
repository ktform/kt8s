{
    "cases": {
        "simple_image": "FROM ubuntu",
        "image_with_tag": "FROM ubuntu:20.04",
        "image_with_alias": "FROM ubuntu AS base",
        "image_with_tag_and_alias": "FROM ubuntu:20.04 AS base",
        "image_with_platform": "--platform=linux/amd64 FROM ubuntu",
        "image_with_all_parameters": "--platform=linux/amd64 FROM ubuntu:20.04 AS base",
        "scratch_image": "FROM scratch",
        "run_single_command": "RUN apt-get update",
        "run_multiple_commands": "RUN apt-get update\nRUN apt-get install -y curl",
        "simple_copy": "COPY src/ /app/",
        "copy_with_from_stage": "COPY --from=builder app.jar /app/",
        "copy_with_chown": "COPY --chown=user:group app.jar /app/",
        "copy_with_chmod": "COPY --chmod=755 script.sh /usr/local/bin/",
        "copy_with_all_options": "COPY --from=builder --chown=user:group --chmod=644 app.jar /app/",
        "simple_add": "ADD file.tar.gz /app/",
        "add_with_chown": "ADD --chown=user:group file.tar.gz /app/",
        "add_with_chmod": "ADD --chmod=755 file.tar.gz /app/",
        "add_with_checksum": "ADD --checksum=sha256:abc123 file.tar.gz /app/",
        "add_with_all_options": "ADD --chown=user:group --chmod=755 --checksum=sha256:abc123 file.tar.gz /app/",
        "absolute_path": "WORKDIR /app",
        "relative_path": "WORKDIR src",
        "default_protocol_tcp_": "EXPOSE 8080/tcp",
        "explicit_tcp_protocol": "EXPOSE 8080/tcp",
        "udp_protocol": "EXPOSE 53/udp",
        "single_variable": "ENV NODE_ENV=production",
        "multiple_variables_using_vararg": "ENV NODE_ENV=production\nENV PORT=3000",
        "cmd_single_command": "CMD [\"node\", \"app.js\"]",
        "cmd_with_arguments": "CMD [\"java\", \"-jar\", \"app.jar\", \"--server.port=8080\"]",
        "exec_form": "ENTRYPOINT [\"java\", \"-jar\", \"app.jar\"]",
        "shell_form": "ENTRYPOINT java -jar app.jar",
        "single_label": "LABEL version=\"1.0\"",
        "multiple_labels": "LABEL version=\"1.0\" maintainer=\"team@example.com\"",
        "user_only": "USER appuser",
        "user_with_group": "USER appuser:appgroup",
        "single_volume": "VOLUME /data",
        "multiple_volumes": "VOLUME [\"/data\", \"/logs\", \"/config\"]",
        "arg_without_default": "ARG BUILD_VERSION",
        "arg_with_default_value": "ARG NODE_VERSION=18",
        "disable_healthcheck": "HEALTHCHECK NONE",
        "simple_healthcheck": "HEALTHCHECK CMD curl -f http://localhost:8080/health",
        "healthcheck_with_all_options": "HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 CMD curl -f http://localhost:8080/health",
        "sigterm": "STOPSIGNAL SIGTERM",
        "sigkill": "STOPSIGNAL SIGKILL",
        "bash_shell": "SHELL [\"/bin/bash\", \"-c\"]",
        "powershell": "SHELL [\"powershell\", \"-command\"]",
        "onbuild_copy": "ONBUILD COPY . /app",
        "onbuild_run": "ONBUILD RUN make /app",
        "with_bind_mount": "RUN --mount=type=bind,source=/host/src,target=/app/src,readonly make build",
        "with_cache_mount": "RUN --mount=type=cache,target=/go/pkg/mod,id=go-mod,sharing=shared go build .",
        "with_tmpfs_mount": "RUN --mount=type=tmpfs,target=/tmp,size=100m npm test",
        "with_secret_mount": "RUN --mount=type=secret,id=mysecret,target=/run/secrets/mysecret echo $SECRET",
        "with_ssh_mount": "RUN --mount=type=ssh,id=default git clone git@github.com:user/repo.git",
        "with_multiple_mounts": "RUN --mount=type=cache,target=/root/.npm,id=npm-cache,sharing=shared --mount=type=bind,source=/host/package.json,target=/app/package.json,readonly npm install",
        "with_network_none": "RUN --network=none go build .",
        "with_security_no_new_privs": "RUN --security=no-new-privs make install",
        "with_all_options": "RUN --mount=type=cache,target=/go/pkg/mod,id=go-mod,sharing=shared --network=none --security=no-new-privs go build .",
        "with_bind_mount_using_dsl": "RUN --mount=type=bind,source=/host/src,target=/app/src,readonly make build",
        "with_cache_mount_using_dsl": "RUN --mount=type=cache,target=/go/pkg/mod,id=go-mod,sharing=shared --mount=type=cache,target=/root/.cache/go-build,id=go-build,sharing=shared go build .",
        "with_tmpfs_mount_using_dsl": "RUN --mount=type=tmpfs,target=/tmp,size=100m,mode=1777 npm test",
        "with_secret_mount_using_dsl": "RUN --mount=type=secret,id=api-token,target=/run/secrets/token,required cat /run/secrets/token",
        "with_ssh_mount_using_dsl": "RUN --mount=type=ssh,id=github,target=/root/.ssh/id_rsa git clone git@github.com:user/repo.git",
        "with_network_and_security_using_dsl": "RUN --network=none --security=no-new-privs make install",
        "with_complex_configuration_using_dsl": "RUN --mount=type=cache,target=/root/.npm,id=npm-cache,sharing=shared --mount=type=bind,source=/host/src,target=/app/src,readonly --mount=type=tmpfs,target=/tmp,size=500m --network=default --security=no-new-privs npm ci && npm run build",
        "env_with_dsl_block": "ENV NODE_ENV=production\nENV PORT=3000\nENV DEBUG=false",
        "label_with_dsl_block": "LABEL version=\"1.0.0\" maintainer=\"team@company.com\" description=\"My awesome app\"",
        "healthcheck_with_dsl_block": "HEALTHCHECK --interval=30s --timeout=10s --retries=3 CMD curl -f http://localhost:3000/health",
        "node_js_application": "FROM node:18-alpine\nWORKDIR /app\nCOPY package*.json ./\nRUN npm ci --only=production\nCOPY . .\nEXPOSE 3000/tcp\nUSER node\nCMD [\"node\", \"server.js\"]",
        "multi_stage_java_build": "FROM maven:3.8-openjdk-17 AS builder\nWORKDIR /app\nCOPY pom.xml .\nCOPY src src\nRUN mvn clean package -DskipTests\nFROM openjdk:17-jre-slim\nWORKDIR /app\nCOPY --from=builder app.jar /app/\nEXPOSE 8080/tcp\nHEALTHCHECK --interval=30s --timeout=3s CMD curl -f http://localhost:8080/actuator/health || exit 1\nENTRYPOINT [\"java\", \"-jar\", \"app.jar\"]"
    }
}